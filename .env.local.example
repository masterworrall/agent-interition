# Local environment overrides for agent-interition build steps.
# Copy to .env.local (gitignored) and set the values you need.
#
# All variables here are OPTIONAL. Default behaviour ships nothing
# anywhere internal.

# SOLID_OPS_DEPLOY_DIR
# --------------------
# Where `npm run install:team-tools` should copy the built solid-ops
# binary. Used by team deployments that want a stable shared path
# (see scripts/install-team-tools.sh). Leave unset to disable.
#
# Typical team value (Mac):
#   SOLID_OPS_DEPLOY_DIR=$HOME/Development/interition/team-tools/solid-ops
#
SOLID_OPS_DEPLOY_DIR=
