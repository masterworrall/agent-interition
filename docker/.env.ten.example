# LLM provider — use ONE of:
#   ANTHROPIC_API_KEY for Anthropic (per-token billing)
#   OpenAI OAuth via ./start-ten.sh auth (flat-rate subscription)
# Leave ANTHROPIC_API_KEY blank if using OpenAI OAuth.
ANTHROPIC_API_KEY=
INTERITION_PASSPHRASE=interition
OPENCLAW_TEN_TOKEN=generate-a-random-token-here
TELEGRAM_BOT_TOKEN=paste-botfather-token-here
TELEGRAM_ALLOWED_USER_ID=your-numeric-telegram-id
