# LLM provider — use ONE of:
#   ANTHROPIC_API_KEY for Anthropic (per-token billing)
#   OpenAI OAuth via ./start-thirteen.sh auth (flat-rate subscription)
# Leave ANTHROPIC_API_KEY blank if using OpenAI OAuth.
ANTHROPIC_API_KEY=
INTERITION_PASSPHRASE=interition
OPENCLAW_THIRTEEN_TOKEN=generate-a-random-token-here
TELEGRAM_BOT_TOKEN=paste-botfather-token-here
TELEGRAM_ALLOWED_USER_ID=your-numeric-telegram-id
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret
